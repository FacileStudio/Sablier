# Required for production — set to your public frontend URL(s)
DOMAINS=https://app.yourdomain.com

# OIDC (optional — enable to use Authentik or any OpenID Connect provider)
# OIDC_ISSUER=https://authentik.yourdomain.com/application/o/sablier/
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URL=https://api.yourdomain.com/auth/oidc/callback
# OIDC_SUCCESS_URL=https://app.yourdomain.com  # defaults to first DOMAINS entry

# Override defaults only if needed
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/sablier?sslmode=disable
# PORT=4000
# LOG_LEVEL=info

# Client (build-time arg for Docker)
# VITE_API_BASE_URL=https://api.yourdomain.com
